# ============================================================
# VECTORLESS RAG PERSONAL FINANCE ASSISTANT — ENV TEMPLATE
# Copy this file to .env and fill in your real API keys.
# NEVER commit .env to version control.
# ============================================================

# --- PRIMARY LLM: xAI Grok-3 ---
XAI_API_KEY=your_xai_api_key_here
GROK_MODEL=grok-3

# --- FALLBACK LLMs (optional) ---
# GROQ_API_KEY=your_groq_api_key_here
# GEMINI_API_KEY=your_gemini_api_key_here
# OPENAI_API_KEY=your_openai_api_key_here

# --- WEB SEARCH ---
TAVILY_API_KEY=your_tavily_api_key_here

# --- PROVIDER SELECTION: xai | groq | gemini | openai ---
DEFAULT_PROVIDER=xai

# --- RAG PIPELINE ---
NUM_SUBQUERIES=4
TOP_K_RERANK=8
TREE_EXPANSION_BREADTH=3
MAX_BOOKS_TO_ROUTE=4
MAX_CHAPTERS_PER_BOOK=3
MAX_SECTIONS_PER_CHAPTER=3

# --- TOKEN BUDGETS (grok-3 = 131K context window) ---
TOKEN_BUDGET_BOOK_ROUTING=8000
TOKEN_BUDGET_CHAPTER_SELECT=4000
TOKEN_BUDGET_SECTION_SELECT=2000
TOKEN_BUDGET_ANSWER_SYNTHESIS=12000
CONTEXT_TOKEN_BUDGET_PER_STEP=4000

# --- RERANKING ---
CROSS_ENCODER_ENABLED=false
DEEP_RESEARCH_CROSS_ENCODER=true
CROSS_ENCODER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
MIN_RELEVANCE_SCORE=6.0

# --- WEB SEARCH BEHAVIOR ---
ENABLE_WEB_SEARCH_FALLBACK=true
